DISCORD_TOKEN=your_bot_token_here
MODMAIL_FORUM_ID=your_forum_channel_id_here
MOD_LOG_CHANNEL_ID=your_log_channel_id_here

# Optional Railway channel variables. Leave blank to use the fallback behavior.
# SERVER_LOG_CHANNEL_ID falls back to MOD_LOG_CHANNEL_ID.
# INVITE_LOG_CHANNEL_ID falls back to SERVER_LOG_CHANNEL_ID, then MOD_LOG_CHANNEL_ID.
SERVER_LOG_CHANNEL_ID=your_server_log_channel_id_here
INVITE_LOG_CHANNEL_ID=your_invite_log_channel_id_here

STAFF_APPLICATION_CHANNEL_ID=your_staff_application_review_channel_id_here
MODERATOR_ROLE_ID=your_moderator_role_id_here
ADMIN_ROLE_ID=your_admin_role_id_here
LEVEL_UP_CHANNEL_ID=your_level_up_channel_id_here
VERIFIED_ROLE_ID=your_verified_role_id_here

# Railway PostgreSQL plugin URL. Leave blank if you are not using PostgreSQL.
DATABASE_URL=postgresql://username:password@host:5432/database
LEVEL_XP_INCREMENT=10
ANTI_RAID_ENABLED=true
ANTI_RAID_JOIN_THRESHOLD=5
ANTI_RAID_WINDOW_SECONDS=20
ANTI_RAID_LOCKDOWN_MINUTES=10
ANTI_RAID_ACCOUNT_AGE_MINUTES=30
ANTI_RAID_TIMEOUT_MINUTES=30
BOT_STATUS_TEXT=Guardian of Honor of Kings | Northeast india
